{
  "name": "astrology-r3f-glb-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node tools/local_dev.js",
    "dev:api": "node tools/local_functions_server.js",
    "dev:netlify": "npx netlify-cli dev",
    "dev:vite": "vite --host 127.0.0.1",
    "voice": ".venv-voice/bin/python tools/voice_server.py",
    "voice:install": "uv pip install --python .venv-voice/bin/python -r requirements-voice.txt",
    "voice:venv": "uv venv --python 3.11 --clear .venv-voice",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.8",
    "@react-three/fiber": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  }
}
